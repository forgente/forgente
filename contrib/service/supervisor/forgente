[program:forgente]
directory=/home/git/forgente/
command=/home/git/forgente/forgente web
autostart=true
autorestart=true
startsecs=10
stdout_logfile=/var/log/forgente/stdout.log
stdout_logfile_maxbytes=1MB
stdout_logfile_backups=10
stdout_capture_maxbytes=1MB
stderr_logfile=/var/log/forgente/stderr.log
stderr_logfile_maxbytes=1MB
stderr_logfile_backups=10
stderr_capture_maxbytes=1MB
user = git
environment = HOME="/home/git", USER="git"